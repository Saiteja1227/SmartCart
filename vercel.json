{
  "buildCommand": "cd something && npm run build",
  "outputDirectory": "something/build",
  "installCommand": "cd something && npm install",
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.+\\.(js|css|png|jpg|jpeg|gif|ico|svg|json))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
